<%
var items = joe_related(post);
var home = theme.home || {};
var relatedConf = theme.related_posts || {};
var relatedTitle = relatedConf.title || '相关推荐';
var defaultThumb = home.default_thumbnail || '/img/default_thumbnail.png';
var palette = home.solid_thumbnails || [
  '#fb6c28', '#5b8ff9', '#5ad8a6', '#f6bd16', '#e8684a',
  '#6dc8ec', '#9270ca', '#ff9d4d', '#269a99', '#ff99c3'
];

function solidCover(seed) {
  var hash = 0;
  var text = String(seed || '');
  for (var i = 0; i < text.length; i++) {
    hash = ((hash << 5) - hash) + text.charCodeAt(i);
    hash |= 0;
  }
  var color = palette[Math.abs(hash) % palette.length];
  return {
    color: color,
    src: 'data:image/svg+xml,' + encodeURIComponent(
      '<svg xmlns="http://www.w3.org/2000/svg" width="800" height="450" viewBox="0 0 800 450"><rect width="800" height="450" fill="' + color + '"/></svg>'
    )
  };
}

function relatedCover(item) {
  var raw = item.cover || (item.photos && item.photos.length ? item.photos[0] : '') || '';
  var cover = String(raw || '').trim();
  if (cover && cover !== defaultThumb && cover.indexOf('default_thumbnail') === -1) {
    return { src: url_for(cover), color: '' };
  }
  return solidCover(item.path || item.slug || item.title);
}
%>
<% if (items && items.length) { %>
  <section class="joe_detail__related">
    <div class="joe_detail__related-title"><%= relatedTitle %></div>
    <div
      class="joe_detail__related-content"
      style="grid-template-columns: repeat(<%= Math.min(items.length, 4) %>, minmax(0, 1fr));"
    >
      <% items.forEach(function (item) { %>
        <% var coverInfo = relatedCover(item); %>
        <a class="item" href="<%= url_for(item.path) %>" title="<%= item.title || __('untitled') %>">
          <img
            src="<%= coverInfo.src %>"
            alt="<%= item.title || __('untitled') %>"
            loading="lazy"
            <% if (coverInfo.color) { %>style="background-color: <%= coverInfo.color %>;"<% } %>
          />
          <h6><%= item.title || __('untitled') %></h6>
        </a>
      <% }) %>
    </div>
  </section>
<% } %>

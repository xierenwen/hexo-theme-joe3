<% if (theme.search && theme.search.enable) { %>
  <% var searchPath = theme.search.path || 'search.json'; %>
  <div class="joe_search" data-search-path="<%= url_for(searchPath) %>" aria-hidden="true" hidden>
    <style>
      .joe_search[hidden]{display:none}.joe_search{position:fixed;inset:0;z-index:9999}.joe_search__mask{position:absolute;inset:0;background:rgba(0,0,0,.55)}.joe_search__panel{position:relative;width:min(720px,calc(100% - 32px));max-height:80vh;margin:10vh auto;padding:24px;border-radius:16px;background:var(--background,#fff);box-shadow:0 20px 60px rgba(0,0,0,.25);overflow:auto}.joe_search__header{display:flex;align-items:center;justify-content:space-between;gap:16px;margin-bottom:16px}.joe_search__title{margin:0;font-size:20px}.joe_search__close{border:0;background:transparent;font-size:28px;line-height:1;cursor:pointer}.joe_search__input{box-sizing:border-box;width:100%;padding:12px 14px;border:1px solid rgba(125,125,125,.35);border-radius:10px;background:transparent;color:inherit}.joe_search__result{display:block;padding:14px 0;border-bottom:1px solid rgba(125,125,125,.18);color:inherit;text-decoration:none}.joe_search__result-title{display:block;margin-bottom:6px;font-weight:600}.joe_search__result-content{margin:0;color:rgba(90,90,90,.9);line-height:1.7}.joe_search__empty{padding:20px 0;color:rgba(90,90,90,.9)}
    </style>
    <div class="joe_search__mask" data-search-close></div>
    <section class="joe_search__panel" role="dialog" aria-modal="true" aria-labelledby="joe-search-title">
      <div class="joe_search__header">
        <h2 id="joe-search-title" class="joe_search__title"><%= __('search') || 'Search' %></h2>
        <button type="button" class="joe_search__close" data-search-close aria-label="Close search">&times;</button>
      </div>
      <input class="joe_search__input" type="search" placeholder="Search posts..." autocomplete="off">
      <div class="joe_search__results" role="list"></div>
    </section>
  </div>
<% } %>

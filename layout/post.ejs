<div class="joe_main joe_post page-post">
  <article class="joe_detail">
    <header class="joe_detail__header">
      <h1 class="joe_detail__title"><%= page.title %></h1>
      <div class="joe_detail__meta">
        <time datetime="<%= date_xml(page.date) %>"><%= date(page.date, 'YYYY-MM-DD') %></time>
        <% if (theme.wordcount && theme.wordcount.enable) { %>
          <span><%= joe_wordcount(page.content || page.raw || '') %> 字</span>
          <span>约 <%= joe_reading_time(page.content || page.raw || '') %> 分钟</span>
        <% } %>
      </div>
    </header>
    <div class="joe_detail__article markdown-body">
      <%- page.content %>
    </div>
    <%- partial('_partial/related', { post: page }) %>
    <%- partial('_partial/comments') %>
  </article>
</div>
<% if (theme.toc && theme.toc.enable) { %>
  <%- partial('_partial/toc') %>
<% } %>
